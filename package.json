{
  "name": "nestedul",
  "version": "2.0.0",
  "type": "module",
  "description": "Make multi-level nested UL lists as trees and add child element disclosure.",
  "keywords": [
    "nested",
    "ul",
    "list",
    "tree",
    "dropdown"
  ],
  "main": "dist/nestedul.cjs.js",
  "module": "dist/nestedul.esm.js",
  "browser": "dist/nestedul.iife.js",
  "exports": {
    ".": {
      "import": "./dist/nestedul.esm.js",
      "require": "./dist/nestedul.cjs.js"
    },
    "./scss": "./dist/nestedul.scss",
    "./style": "./dist/nestedul.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build:js": "node build.js",
    "build:css": "sass src/nestedul.scss dist/nestedul.css && sass src/nestedul.scss dist/nestedul.min.css --style=compressed",
    "build:scss": "cpy \"src/**/*.scss\" dist",
    "build:assets": "cpy \"src/nestedul_assets/**/*\" dist/nestedul_assets",
    "build": "npm run clean && npm run build:js && npm run build:css && npm run build:scss && npm run build:assets"
  },
  "devDependencies": {
    "cpy-cli": "^7.0.0",
    "esbuild": "^0.27.3",
    "jquery": "^4.0.0",
    "rimraf": "^6.1.3",
    "sass": "^1.97.3"
  },
  "author": "Zlatov",
  "license": "ISC"
}
